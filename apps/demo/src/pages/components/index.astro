---
import Layout from "../../layouts/Layout.astro"
import ComponentsSidebarLayout from "../../layouts/ComponentsSidebarLayout.astro"
import { components } from "../../lib/components"
import { COMPONENT_STATUS_META } from "@/lib/component-status"
const base = import.meta.env.BASE_URL.replace(/\/$/, "")
---

<Layout title="Components">
  <ComponentsSidebarLayout currentPath={`${base}/components`}>
    <div class="flex flex-col gap-6">
      <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-bold">Components</h1>
        <p class="text-muted-foreground">
          Explore the Omni UI component library. Each page showcases the
          Omni-styled registry implementation alongside installation and usage
          guidelines.
        </p>
      </div>

      <div class="grid gap-2 sm:grid-cols-2">
        {components.map((item) => {
          const statusMeta = COMPONENT_STATUS_META[item.status]
          return (
            <a
              href={`${base}/components/${item.name}`}
              class="flex items-center justify-between border border-border/70 bg-card/30 px-4 py-3 text-sm transition hover:border-primary/60 hover:bg-card/50"
            >
              <span class="font-medium text-foreground">{item.title}</span>
              {statusMeta && (
                <span class:list={[
                  "inline-flex items-center border px-1.5 py-0 text-xs font-medium leading-4 opacity-70",
                  statusMeta.className
                ]}>
                  {statusMeta.label}
                </span>
              )}
            </a>
          )
        })}
      </div>
    </div>
  </ComponentsSidebarLayout>
</Layout>
